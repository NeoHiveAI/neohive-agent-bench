{
  "$schema": "https://opencode.ai/config.json",
  "permission": { "*": "allow" },
  "instructions": ["instructions/neohive.md"],
  "plugin": ["./plugin/neohive.ts", "./plugin/neohive-smart-prompts.ts"],
  "mcp": {
    "neohive": {
      "type": "remote",
      "url": "https://neohive.logilica.com/projects/__NEOHIVE_PROJECT__/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "CF-Access-Client-Id": "{env:NEOHIVE_CF_ACCESS_CLIENT_ID}",
        "CF-Access-Client-Secret": "{env:NEOHIVE_CF_ACCESS_CLIENT_SECRET}",
        "User-Agent": "opencode-neohive/0.1"
      }
    }
  }
}
